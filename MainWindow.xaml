<Window x:Class="CyberBotGUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cyber Bot - Cybersecurity Awareness"
        Height="720" Width="850"
        Background="#F0F0F0"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="20">

        <!-- NAME ENTRY SCREEN -->
        <Grid x:Name="NameScreen" Visibility="Visible">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="150"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Logo image from the Image folder -->
            <Image Grid.Row="0" Grid.ColumnSpan="2"
                   Source="Image/logo.jpg"
                   Width="400"
                   Height="200"
                   Stretch="Uniform"
                   HorizontalAlignment="Center"
                   Margin="0,10,0,20"/>

            <!-- Name label and input -->
            <Label Grid.Row="1" Grid.Column="0"
                   Content="Enter Your Name:"
                   FontSize="13"
                   Margin="5"
                   VerticalAlignment="Center"/>

            <TextBox x:Name="NameInput"
                     Grid.Row="1" Grid.Column="1"
                     FontSize="13"
                     Height="30"
                     Margin="5"
                     KeyDown="NameInput_KeyDown"/>

            <!-- Error message shown if name is empty -->
            <TextBlock x:Name="NameError"
                       Grid.Row="2" Grid.ColumnSpan="2"
                       Text="Please enter your name to continue."
                       Foreground="Red"
                       FontSize="11"
                       HorizontalAlignment="Center"
                       Visibility="Collapsed"
                       Margin="5"/>

            <!-- Start button -->
            <StackPanel Grid.Row="3" Grid.ColumnSpan="2"
                        Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        Margin="10">

                <Button x:Name="StartButton"
                        Content="Start Chatting"
                        Width="140"
                        Height="35"
                        Margin="5"
                        Background="LightBlue"
                        Click="StartButton_Click"/>
            </StackPanel>

        </Grid>

        <!-- CHAT SCREEN -->
        <Grid x:Name="ChatScreen" Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Header showing user name -->
            <TextBlock x:Name="HeaderUserName"
                       Grid.Row="0" Grid.ColumnSpan="2"
                       FontSize="14"
                       FontWeight="Bold"
                       Margin="0,0,0,10"/>

            <!-- Chat message area -->
            <ScrollViewer x:Name="ChatScroll"
                          Grid.Row="1" Grid.ColumnSpan="2"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Background="White"
                          BorderBrush="LightGray"
                          BorderThickness="1"
                          Margin="0,0,0,8">
                <StackPanel x:Name="MessagePanel"
                            Margin="10"
                            CanHorizontallyScroll="False"/>
            </ScrollViewer>

            <!-- Input row -->
            <TextBox x:Name="MessageInput"
                     Grid.Row="2" Grid.Column="0"
                     FontSize="13"
                     Height="35"
                     Margin="0,0,8,0"
                     KeyDown="MessageInput_KeyDown"/>

            <Button x:Name="SendButton"
                    Grid.Row="2" Grid.Column="1"
                    Content="Send"
                    Width="80"
                    Height="35"
                    Background="LightBlue"
                    Click="SendButton_Click"/>

        </Grid>

    </Grid>
</Window>